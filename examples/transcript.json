{
  "name": "multi-demo",
  "steps": [
    {
      "request": {"tool": "echo", "input": {"text": "hello opensperm"}},
      "response": {"output": {"text": "hello opensperm"}}
    },
    {
      "request": {"tool": "uppercase", "input": {"text": "hello opensperm"}},
      "response": {"output": {"text": "HELLO OPENSPERM"}}
    },
    {
      "request": {"tool": "reverse", "input": {"text": "hello opensperm"}},
      "response": {"output": {"text": "mrepsnepo olleh"}}
    },
    {
      "request": {"tool": "http_mock", "input": {"url": "https://example.com/mock"}},
      "response": {"output": {"url": "https://example.com/mock", "status": 200, "body": "mocked"}}
    },
    {
      "request": {"tool": "http_fetch", "input": {"url": "https://example.com"}},
      "response": {"output": {"raw": ""}}
    }
  ]
}
