{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://opensperm.dev/schemas/skill-manifest.schema.json",
  "title": "SkillManifest",
  "type": "object",
  "required": ["name", "version", "language", "entry", "inputs", "outputs", "capabilities"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[A-Za-z0-9.-]+)?$" },
    "language": { "type": "string", "enum": ["typescript", "rust"] },
    "entry": { "type": "string", "description": "Path to compiled skill entry point." },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" },
            "required": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "network": {
          "type": "object",
          "properties": {
            "egress": { "type": "array", "items": { "type": "string", "format": "uri" } }
          }
        },
        "filesystem": {
          "type": "object",
          "properties": {
            "paths": { "type": "array", "items": { "type": "string" } },
            "mode": { "type": "string", "enum": ["ro", "rw"] }
          }
        },
        "secrets": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "policyScopes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Named policy scopes required by this skill."
    },
    "signing": {
      "type": "object",
      "required": ["algorithm", "signature", "publicKey"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["ed25519"] },
        "signature": { "type": "string" },
        "publicKey": { "type": "string" },
        "manifestHash": { "type": "string", "description": "Hash of manifest content for integrity." }
      }
    }
  },
  "additionalProperties": false
}
